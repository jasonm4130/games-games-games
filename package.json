{
  "name": "games-games-games",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare-native RAG-over-rulebooks app — answers tabletop game rules questions, grounded and cited.",
  "license": "MIT",
  "author": "Jason Matthew <jasonm4130@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonm4130/games-games-games.git"
  },
  "homepage": "https://games.jasonmatthew.dev",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "pnpm --filter worker dev",
    "build": "pnpm --filter worker build",
    "deploy": "pnpm --filter worker deploy",
    "types": "pnpm --filter worker types",
    "test:watch": "pnpm --filter worker test:watch",
    "ingest": "pnpm --filter operator-scripts ingest",
    "eval": "pnpm --filter operator-scripts eval",
    "inject-eval": "pnpm --filter operator-scripts inject-eval",
    "gen-gold": "pnpm --filter operator-scripts gen-gold",
    "rerank-calibrate": "pnpm --filter operator-scripts rerank-calibrate",
    "answerability-eval": "pnpm --filter operator-scripts answerability-eval",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check . && pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0"
  }
}
