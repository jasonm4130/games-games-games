{
  "name": "games-games-games",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare-native RAG-over-rulebooks app — answers tabletop game rules questions, grounded and cited.",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check . && tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.204",
    "@cloudflare/ai-chat": "^0.8.5",
    "@langchain/textsplitters": "^1.0.1",
    "agents": "^0.16.0",
    "ai": "^6.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@biomejs/biome": "2.5.0",
    "@cloudflare/vite-plugin": "^1.40.2",
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260602.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.96.0"
  }
}
